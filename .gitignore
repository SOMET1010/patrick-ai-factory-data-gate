# Virtual environment
.venv/

# Python
__pycache__/
*.py[cod]

# Pytest / Ruff caches
.pytest_cache/
.ruff_cache/

# Coverage
.coverage
htmlcov/
coverage.xml

# Secrets / local configuration (never commit)
.env
.env.*
!.env.example

# Generated artifacts
artifacts/*.log
artifacts/*.json

# Keep the directory
!artifacts/.gitkeep
*.egg-info/

# Build output
build/
dist/
