# Copy to `.env` and fill in your own value. NEVER commit the real .env.
#
# Connection string for the database to inspect. Use a dedicated READ-ONLY
# PostgreSQL role — the Data Gate never writes, but least privilege is enforced
# defense-in-depth.
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATAGATE_DSN=postgresql://datagate_ro:CHANGE_ME@localhost:5432/your_database
